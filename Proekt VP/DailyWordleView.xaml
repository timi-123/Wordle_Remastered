<UserControl x:Class="Proekt_VP.DailyWordleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:Proekt_VP.Controls"
             mc:Ignorable="d"
             Focusable="True"
             KeyDown="DailyWordleView_KeyDown"
             d:DesignHeight="700"
             d:DesignWidth="1100">

    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="← Back to Menu"
                    Padding="10,5"
                    Click="BackButton_Click"/>

            <TextBlock Grid.Column="1"
                       Text="UNLIMITED WORDLE"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">

            <TextBlock Text="Played: "
                       FontSize="16"/>

            <TextBlock Text="{Binding GamesPlayed,
                                      Mode=OneWay}"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,20,0"/>

            <TextBlock Text="Won: "
                       FontSize="16"/>

            <TextBlock Text="{Binding GamesWon,
                                      Mode=OneWay}"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,20,0"/>

            <TextBlock Text="Lost: "
                       FontSize="16"/>

            <TextBlock Text="{Binding GamesLost,
                                      Mode=OneWay}"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,20,0"/>

            <TextBlock Text="Win: "
                       FontSize="16"/>

            <TextBlock FontSize="16"
                       FontWeight="Bold">

                <Run Text="{Binding WinPercentage,
                                   Mode=OneWay,
                                   StringFormat={}{0:F0}}"/>

                <Run Text="%"/>

            </TextBlock>

        </StackPanel>

        <Grid Grid.Row="2"
              Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <controls:WordleBoardControl
                    Grid.Row="0"
                    x:Name="Board"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            Margin="10">

                    <TextBlock Text="{Binding ErrorMessage,
                                              Mode=OneWay}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="5"/>

                    <Button Content="PLAY AGAIN"
                            Width="170"
                            Height="42"
                            Margin="5"
                            FontWeight="Bold"
                            Command="{Binding NewGameCommand}">

                        <Button.Style>
                            <Style TargetType="Button">

                                <Setter Property="Visibility"
                                        Value="Collapsed"/>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding IsGameOver}"
                                                 Value="True">

                                        <Setter Property="Visibility"
                                                Value="Visible"/>

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>
                        </Button.Style>

                    </Button>

                </StackPanel>

            </Grid>

            <Border Grid.Column="1"
                    Width="330"
                    Padding="18"
                    Margin="25,0,0,0"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8"
                    VerticalAlignment="Center">

                <Border.Style>
                    <Style TargetType="Border">

                        <Setter Property="Visibility"
                                Value="Collapsed"/>

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding IsGameOver}"
                                         Value="True">

                                <Setter Property="Visibility"
                                        Value="Visible"/>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>
                </Border.Style>

                <StackPanel>

                    <TextBlock Text="SESSION STATISTICS"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,15">

                        <StackPanel Margin="8,0">

                            <TextBlock Text="{Binding GamesPlayed,
                                                      Mode=OneWay}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Played"
                                       HorizontalAlignment="Center"/>

                        </StackPanel>

                        <StackPanel Margin="8,0">

                            <TextBlock Text="{Binding GamesWon,
                                                      Mode=OneWay}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Won"
                                       HorizontalAlignment="Center"/>

                        </StackPanel>

                        <StackPanel Margin="8,0">

                            <TextBlock Text="{Binding GamesLost,
                                                      Mode=OneWay}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Lost"
                                       HorizontalAlignment="Center"/>

                        </StackPanel>

                    </StackPanel>

                    <TextBlock Text="GUESS DISTRIBUTION"
                               FontSize="17"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,12"/>

                    <Grid Width="260">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="25"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="34"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="1"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Width="{Binding Distribution1Width,
                                                Mode=OneWay}"
                                Height="25"
                                Background="#538D4E"
                                HorizontalAlignment="Left">

                            <TextBlock Text="{Binding WonIn1,
                                                      Mode=OneWay}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="5,0"/>

                        </Border>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="2"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Width="{Binding Distribution2Width,
                                                Mode=OneWay}"
                                Height="25"
                                Background="#538D4E"
                                HorizontalAlignment="Left">

                            <TextBlock Text="{Binding WonIn2,
                                                      Mode=OneWay}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="5,0"/>

                        </Border>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="3"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <Border Grid.Row="2"
                                Grid.Column="1"
                                Width="{Binding Distribution3Width,
                                                Mode=OneWay}"
                                Height="25"
                                Background="#538D4E"
                                HorizontalAlignment="Left">

                            <TextBlock Text="{Binding WonIn3,
                                                      Mode=OneWay}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="5,0"/>

                        </Border>

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Text="4"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <Border Grid.Row="3"
                                Grid.Column="1"
                                Width="{Binding Distribution4Width,
                                                Mode=OneWay}"
                                Height="25"
                                Background="#538D4E"
                                HorizontalAlignment="Left">

                            <TextBlock Text="{Binding WonIn4,
                                                      Mode=OneWay}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="5,0"/>

                        </Border>

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Text="5"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <Border Grid.Row="4"
                                Grid.Column="1"
                                Width="{Binding Distribution5Width,
                                                Mode=OneWay}"
                                Height="25"
                                Background="#538D4E"
                                HorizontalAlignment="Left">

                            <TextBlock Text="{Binding WonIn5,
                                                      Mode=OneWay}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="5,0"/>

                        </Border>

                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Text="6"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <Border Grid.Row="5"
                                Grid.Column="1"
                                Width="{Binding Distribution6Width,
                                                Mode=OneWay}"
                                Height="25"
                                Background="#538D4E"
                                HorizontalAlignment="Left">

                            <TextBlock Text="{Binding WonIn6,
                                                      Mode=OneWay}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="5,0"/>

                        </Border>

                    </Grid>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</UserControl>