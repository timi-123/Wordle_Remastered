<UserControl x:Class="Proekt_VP.SinglePlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Proekt_VP"
             xmlns:controls="clr-namespace:Proekt_VP.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        
        <!-- Za selektiranje duration na igra -->

        <StackPanel x:Name="DurationSelection" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock FontSize="25" Margin="0,0,0,10">Choose a time limit</TextBlock>
            <Button Margin="0,0,0,10" Width="150" Padding="7" Click="OneMinuteClick">1 min</Button>
            <Button Margin="0,0,0,10" Width="150" Padding="7" Click="TwoMinutesClick">2min</Button>
            <Button Width="150" Padding="7" Click="ThreeMinutesClick">5min</Button>
        </StackPanel>
        
        <Button Content="← Back to Menu" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Padding="10,5" Click="BackButton_Click" />
        <controls:WordleBoardControl x:Name="Board" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
    </Grid>
</UserControl>
