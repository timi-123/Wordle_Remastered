<UserControl x:Class="Proekt_VP.SinglePlayerView"
             Focusable="True"
             KeyDown="KeyDownSPV"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Proekt_VP"
             xmlns:controls="clr-namespace:Proekt_VP.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
             
            
    <Grid>
        
        <!-- Za selektiranje duration na igra -->

        <StackPanel x:Name="DurationSelection" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock FontSize="32" FontWeight="Bold" Margin="0,0,0,10">SINGLEPLAYER TIMED MODE</TextBlock>
            <TextBlock FontSize="18" Margin="0,0,0,10" TextAlignment="Center">Choose a time limit</TextBlock>
            <Button Margin="0,6" Width="150" Padding="12,7" FontSize="15" Click="OneMinuteClick">1 min</Button>
            <Button Margin="0,6" Width="150" Padding="12,7" FontSize="15" Click="TwoMinutesClick">2 min</Button>
            <Button Margin="0,6" Width="150" Padding="12,7" FontSize="15" Click="ThreeMinutesClick">3 min</Button>
        </StackPanel>
        
        <Button Content="← Back to Menu" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Padding="10,5" Click="BackButton_Click" />
        

        <Grid x:Name="Game" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <controls:TimerAndScoreControl Grid.Row="0" x:Name="TimerAndScore" HorizontalAlignment="Center" VerticalAlignment="Top" />
            <controls:WordleBoardControl Grid.Row="1" x:Name="Board" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    
    </Grid>
</UserControl>
